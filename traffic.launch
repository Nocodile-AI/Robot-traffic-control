<!--semi_auto with Traffic Management System-->
<!--SPARKæ€æ¯è®¨è®ºä¸åé¦ç¾¤ï¼8346256-->
<launch>
  	<!-- Arguments -->
  	<arg name="slam_methods"           default="gmapping"   doc="slam type [gmapping, cartographer, hector, karto, frontier_exploration]"/>
	<arg name="lidar_type_tel"         default="ydlidar_g6" doc="lidar type [3iroboticslidar2, ydlidar_g2]"/>
	<arg name="camera_type_tel"        default="d435"       doc="camera type [astrapro, astra, d435...]"/>
	<arg name="configuration_basename" default="spark_lds_2d.lua"/>
	<arg name="3d_sensor"              default="3i_lidar"/>  
  	<arg name="open_rviz"              default="true"/>
  	<arg name="enable_traffic"         default="true"       doc="Enable traffic management system"/>
  	<arg name="enable_grasping"        default="true"       doc="Enable object grasping"/>
  	
	<!--sparkåºçé©±å¨ï¼æºå¨äººæè¿°,åºç,ç¸æº-->
	<include file="$(find spark_bringup)/launch/driver_bringup.launch">
		<arg name="camera_type_tel"	value="$(arg camera_type_tel)"/>
		<arg name="lidar_type_tel"	value="$(arg lidar_type_tel)"/>
		<arg name="start_camera" value="true"/>	
	</include>



	<!-- Teleop -->
	<node pkg="raicomworkshop" type="teleop.py" name="teleop" launch-prefix="xterm -e" />

	<!-- Traffic Management System -->
	<group if="$(arg enable_traffic)">
		<node pkg="raicomworkshop" type="traffic_controller.py" name="traffic_controller" output="screen"/>
	</group>
	
	<!-- Object Grasping System -->
	<group if="$(arg enable_grasping)">
		<!-- YOLO Object Detection -->
		<node pkg="raicomworkshop" type="yolo_detector.py" name="yolo_detector" output="screen"/>
		
		<!-- YOLO-based Grasp Controller -->
		<node pkg="raicomworkshop" type="grasp.py" name="grasp_yolo" output="screen"/>
	</group>

</launch>
